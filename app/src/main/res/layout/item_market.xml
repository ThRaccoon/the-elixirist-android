<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#59000000"
    android:contentDescription="@string/cont_desc_none"
    android:padding="8dp">

    <ImageView
        android:id="@+id/item_market_iv_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/cont_desc_none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/btn_market" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/item_market_iv_icon"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/item_market_tv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Item Name" />

        <TextView
            android:id="@+id/item_market_tv_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#BFFFFFFF"
            android:textSize="10sp"
            tools:text="Item description" />
    </LinearLayout>

    <TextView
        android:id="@+id/item_market_tv_owned"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="32dp"
        android:letterSpacing="0.05"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/item_market_tv_price"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="x0" />

    <TextView
        android:id="@+id/item_market_tv_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="135K" />
</androidx.constraintlayout.widget.ConstraintLayout>
