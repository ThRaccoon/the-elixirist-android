<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chronicle"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#4D000000"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:text="@string/chronicle_title"
            android:textColor="#FFFFFF"
            android:textSize="34sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#9A000000"
        android:orientation="horizontal"
        android:padding="8dp">

        <ImageButton
            android:id="@+id/chronicle_ib_main"
            android:layout_width="@dimen/btn_icon_width"
            android:layout_height="@dimen/btn_icon_height"
            android:layout_weight="1"
            android:background="#00FFFFFF"
            android:contentDescription="@string/cont_desc_none"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/btn_main" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:background="?android:attr/listDivider"
            android:backgroundTint="#00FFFFFF" />

        <ImageButton
            android:id="@+id/chronicle_ib_market"
            android:layout_width="@dimen/btn_icon_width"
            android:layout_height="@dimen/btn_icon_height"
            android:layout_weight="1"
            android:background="#00FFFFFF"
            android:contentDescription="@string/cont_desc_none"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/btn_market" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:background="?android:attr/listDivider"
            android:backgroundTint="#00FFFFFF" />

        <LinearLayout
            android:layout_width="@dimen/btn_icon_width"
            android:layout_height="@dimen/btn_icon_height"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/chronicle_ib_chronicle"
                android:layout_width="@dimen/btn_icon_selected_width"
                android:layout_height="@dimen/btn_icon_selected_height"
                android:background="#00FFFFFF"
                android:contentDescription="@string/cont_desc_none"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/btn_chronicle" />

            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="2dp"
                android:background="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>
